generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ============================================
// AUTH
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  phone         String?   @unique
  role          String    @default("CUSTOMER") // CUSTOMER | ADMIN | SUPER_ADMIN
  avatar        String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  addresses     Address[]
  orders        Order[]
  reviews       Review[]
  favorites     Favorite[]
  cart          CartItem[]
  wishlist      Wishlist[]
  sessions      Session[]
  notifications Notification[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// PRODUCTS
// ============================================

model Product {
  id                String          @id @default(cuid())
  name              String
  nameAr            String?
  nameFr            String?
  slug              String          @unique
  description       String?
  descriptionAr     String?
  descriptionFr     String?
  sku               String          @unique
  karat             String          @default("K21") // K18 | K21 | K24
  weight            Float
  goldPrice         Float
  profitMargin      Float
  calculatedPrice   Float
  compareAtPrice    Float?
  stock             Int             @default(0)
  lowStockThreshold Int             @default(5)
  isActive          Boolean         @default(true)
  isFeatured        Boolean         @default(false)
  isNew             Boolean         @default(false)
  certification     String?
  videoUrl          String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  category      Category        @relation(fields: [categoryId], references: [id])
  categoryId    String
  images        ProductImage[]
  variants      ProductVariant[]
  reviews       Review[]
  orderItems    OrderItem[]
  cartItems     CartItem[]
  wishlistItems Wishlist[]
  favorites     Favorite[]
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  order     Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id        String  @id @default(cuid())
  name      String
  sku       String  @unique
  weight    Float
  price     Float
  stock     Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Category {
  id          String     @id @default(cuid())
  name        String
  nameAr      String?
  nameFr      String?
  slug        String     @unique
  description String?
  image       String?
  order       Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  products    Product[]
  children    Category[] @relation("CategoryTree")
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  parentId    String?
}

// ============================================
// PRICING ENGINE
// ============================================

model GoldPrice {
  id        String   @id @default(cuid())
  karat     String // K18 | K21 | K24
  price     Float
  currency  String   @default("MAD")
  source    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model ProfitMargin {
  id         String   @id @default(cuid())
  categoryId String?
  productId  String?
  margin     Float
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ============================================
// ORDERS
// ============================================

model Order {
  id              String   @id @default(cuid())
  orderNumber     String   @unique
  status          String   @default("PENDING") // PENDING|CONFIRMED|PROCESSING|SHIPPED|DELIVERED|CANCELLED|REFUNDED
  subtotal        Float
  shippingCost    Float    @default(0)
  tax             Float    @default(0)
  discount        Float    @default(0)
  total           Float
  currency        String   @default("MAD")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  paidAt          DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?

  userId          String
  user            User     @relation(fields: [userId], references: [id])
  items           OrderItem[]
  shippingAddress Address? @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  shippingAddressId String?
  billingAddress  Address? @relation("BillingAddress", fields: [billingAddressId], references: [id])
  billingAddressId  String?
  payment         Payment?
  shipment        Shipment?
  coupon          Coupon?  @relation(fields: [couponId], references: [id])
  couponId        String?
  reviews         Review[]
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int     @default(1)
  price     Float
  weight    Float
  total     Float
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
}

// ============================================
// PAYMENTS
// ============================================

model Payment {
  id                String   @id @default(cuid())
  amount            Float
  currency          String   @default("MAD")
  status            String   @default("PENDING") // PENDING|PROCESSING|COMPLETED|FAILED|REFUNDED
  method            String // STRIPE|PAYPAL|CASH_ON_DELIVERY|BANK_TRANSFER
  stripePaymentId   String?  @unique
  paypalOrderId     String?  @unique
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  orderId           String   @unique
  order             Order    @relation(fields: [orderId], references: [id])
}

// ============================================
// SHIPPING
// ============================================

model Address {
  id            String  @id @default(cuid())
  firstName     String
  lastName      String
  company       String?
  address1      String
  address2      String?
  city          String
  state         String?
  postalCode    String
  country       String
  phone         String
  isDefault     Boolean @default(false)
  userId        String
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  shippingOrders Order[] @relation("ShippingAddress")
  billingOrders  Order[] @relation("BillingAddress")
}

model Shipment {
  id                String   @id @default(cuid())
  trackingNumber    String?
  carrier           String // DHL|FEDEX|UPS|ARAMEX
  status            String   @default("PENDING") // PENDING|PICKED_UP|IN_TRANSIT|OUT_FOR_DELIVERY|DELIVERED|FAILED
  estimatedDelivery DateTime?
  actualDelivery    DateTime?
  shippingLabelUrl  String?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  orderId           String   @unique
  order             Order    @relation(fields: [orderId], references: [id])
}

// ============================================
// CUSTOMERS
// ============================================

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model CartItem {
  id        String   @id @default(cuid())
  quantity  Int      @default(1)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
}

// ============================================
// REVIEWS
// ============================================

model Review {
  id         String   @id @default(cuid())
  rating     Int
  title      String?
  comment    String?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderId    String?
  order      Order?   @relation(fields: [orderId], references: [id])

  @@unique([userId, productId])
}

// ============================================
// COUPONS
// ============================================

model Coupon {
  id            String   @id @default(cuid())
  code          String   @unique
  description   String?
  discountType  String // PERCENTAGE | FIXED
  discountValue Float
  minPurchase   Float?
  maxDiscount   Float?
  usageLimit    Int?
  usedCount     Int      @default(0)
  isActive      Boolean  @default(true)
  startsAt      DateTime
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders Order[]
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id        String   @id @default(cuid())
  type      String // ORDER_PLACED|ORDER_SHIPPED|ORDER_DELIVERED|PRICE_DROP|NEW_PRODUCT|REVIEW_REQUEST
  title     String
  message   String
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
}

// ============================================
// ANALYTICS
// ============================================

model AnalyticsEvent {
  id        String   @id @default(cuid())
  event     String
  data      Json?
  userId    String?
  sessionId String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
}
